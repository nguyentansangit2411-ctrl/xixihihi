            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"comment\": \"Updated comment\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/sellers/ratings/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "sellers", "ratings", "00000000-0000-0000-0000-000000000000"] }
          }
        }
      ]
