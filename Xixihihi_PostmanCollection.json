          }
        }
      ]
    },
    {
      "name": "Seller Ratings",
      "item": [
        {
          "name": "Get Seller Ratings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/sellers/00000000-0000-0000-0000-000000000000/ratings?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "00000000-0000-0000-0000-000000000000", "ratings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Seller Rating Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/sellers/00000000-0000-0000-0000-000000000000/ratings/summary", "host": ["{{baseUrl}}"], "path": ["api", "sellers", "00000000-0000-0000-0000-000000000000", "ratings", "summary"] }
          }
        },
        {
          "name": "Rate Seller",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
