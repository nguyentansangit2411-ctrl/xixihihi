            "url": { "raw": "{{baseUrl}}/api/sellers/00000000-0000-0000-0000-000000000000/ratings", "host": ["{{baseUrl}}"], "path": ["api", "sellers", "00000000-0000-0000-0000-000000000000", "ratings"] }
          }
